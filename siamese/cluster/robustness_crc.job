export SIGNATURE_RUN_PROFILE="${SIGNATURE_RUN_PROFILE:-full}"
export SIGNATURE_EVAL_SPLIT="${SIGNATURE_EVAL_SPLIT:-test}"

# export SIGNATURE_CHECKPOINT_PATH=/users/smondal/signature-project/repo/siamese/runs/siamese_full_YYYYMMDD-HHMMSS/checkpoints/best.pt

python -m signature_siamese.evaluate_robustness
